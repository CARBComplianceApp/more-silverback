rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.size() >= 2 && data.keys().hasAll(['email', 'createdAt'])
        && data.email is string
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidUser(incoming())
        && incoming().createdAt == request.time;
      allow update: if isSignedIn() 
        && request.auth.uid == userId 
        && incoming().diff(existing()).affectedKeys().hasOnly(['email'])
        && incoming().email is string;
    }

    function isValidGeneration(data) {
      return data.keys().hasAll(['userId', 'type', 'createdAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.type is string && data.type.size() <= 64
        && data.createdAt is timestamp;
    }

    match /generations/{generationId} {
      allow list, get: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid 
        && isValidGeneration(incoming())
        && incoming().createdAt == request.time;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
